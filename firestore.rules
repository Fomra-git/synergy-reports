rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow unauthenticated read access specifically for branding (Logo, Name, etc.)
    match /system_config/branding {
      allow read: if true;
    }

    // Default: Allow read/write access to everything else only if the user is logged in
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
